<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>LUMIK — Maquette iOS hi-fi</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;600;700&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --washi:#14120E; --panel:#1E1A13; --panel2:#26211A;
    --ink:#EFE7D8; --muted:#9A8F7C; --line:#2E281F;
    --shu:#D2603F; --gold:#C9A86A;
    --serif:'Shippori Mincho',serif; --sans:'Zen Kaku Gothic New',system-ui,sans-serif;
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
  body{
    min-height:100vh;display:flex;align-items:center;justify-content:center;gap:54px;flex-wrap:wrap;
    background:
      radial-gradient(1200px 600px at 50% -10%, #20180f, transparent 60%),
      #0c0b08;
    font-family:var(--sans);padding:46px 20px;
  }
  .stage-label{position:fixed;top:18px;left:24px;color:#6f6657;font-size:12px;letter-spacing:.28em;text-transform:uppercase;}

  /* ===== iPhone frame ===== */
  .phone{
    width:390px;height:844px;border-radius:54px;position:relative;flex:0 0 auto;
    background:var(--washi);overflow:hidden;
    box-shadow:0 0 0 12px #1c1a17, 0 0 0 14px #2a2722, 0 40px 90px -20px rgba(0,0,0,.8);
  }
  .notch{position:absolute;top:11px;left:50%;transform:translateX(-50%);width:124px;height:33px;background:#000;border-radius:20px;z-index:60;}
  .statusbar{position:absolute;top:0;left:0;right:0;height:52px;display:flex;align-items:flex-end;justify-content:space-between;
    padding:0 26px 7px;font-size:13px;font-weight:600;color:var(--ink);z-index:55;}
  .statusbar .sb-r{display:flex;gap:6px;align-items:center;}
  .statusbar svg{display:block;}

  .screen{position:absolute;inset:0;padding-top:52px;padding-bottom:84px;overflow:hidden;}
  .view{position:absolute;inset:0;padding-top:52px;padding-bottom:84px;overflow-y:auto;overflow-x:hidden;
    opacity:0;pointer-events:none;transition:opacity .25s;}
  .view.active{opacity:1;pointer-events:auto;}
  .view::-webkit-scrollbar{display:none;}

  /* header */
  .app-head{display:flex;align-items:center;justify-content:space-between;padding:14px 20px 10px;}
  .brand{font-family:var(--serif);font-weight:700;font-size:20px;letter-spacing:.04em;color:var(--ink);display:flex;align-items:center;gap:8px;}
  .brand .lamp{color:var(--shu);}
  .icobtn{position:relative;width:40px;height:40px;border:1px solid var(--line);border-radius:13px;background:var(--panel);
    display:flex;align-items:center;justify-content:center;color:var(--ink);cursor:pointer;}
  .badge{position:absolute;top:-6px;right:-6px;min-width:18px;height:18px;border-radius:9px;background:var(--shu);color:#1a120e;
    font-size:11px;font-weight:700;display:none;align-items:center;justify-content:center;padding:0 5px;}

  /* hero */
  .hero{margin:6px 20px 18px;border:1px solid var(--line);border-radius:22px;overflow:hidden;position:relative;
    background:linear-gradient(160deg,#241c13,#16130d);padding:26px 22px 24px;}
  .hero::before{content:"灯";position:absolute;right:-14px;bottom:-40px;font-family:var(--serif);font-size:190px;color:#fff;opacity:.05;line-height:1;}
  .hero .kj{font-family:var(--serif);font-size:13px;letter-spacing:.34em;color:var(--shu);text-transform:uppercase;font-weight:700;}
  .hero h1{font-family:var(--serif);font-weight:600;font-size:24px;line-height:1.32;color:var(--ink);margin:12px 0 0;max-width:240px;}
  .hero p{color:var(--muted);font-size:12.5px;margin-top:10px;max-width:240px;}
  .hero .seal{position:absolute;top:20px;right:20px;width:50px;height:50px;border:2px solid var(--shu);border-radius:7px;
    display:flex;align-items:center;justify-content:center;font-family:var(--serif);color:var(--shu);font-size:24px;transform:rotate(-7deg);}

  /* region chips */
  .chips{display:flex;gap:9px;overflow-x:auto;padding:2px 20px 16px;scrollbar-width:none;}
  .chips::-webkit-scrollbar{display:none;}
  .chip{flex:0 0 auto;border:1px solid var(--line);background:var(--panel);color:var(--muted);
    font-family:var(--sans);font-size:12.5px;padding:9px 15px;border-radius:999px;cursor:pointer;white-space:nowrap;transition:.18s;}
  .chip .cjp{font-family:var(--serif);color:var(--gold);margin-right:5px;}
  .chip.on{background:var(--shu);border-color:var(--shu);color:#1a120e;font-weight:600;}
  .chip.on .cjp{color:#1a120e;}

  .sec-title{display:flex;align-items:baseline;justify-content:space-between;padding:4px 20px 12px;}
  .sec-title h2{font-family:var(--serif);font-size:17px;color:var(--ink);font-weight:600;}
  .sec-title span{font-size:11.5px;color:var(--muted);}

  /* product grid */
  .grid{display:grid;grid-template-columns:1fr 1fr;gap:13px;padding:0 20px 24px;}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:18px;overflow:hidden;cursor:pointer;transition:transform .15s,border-color .2s;}
  .card:active{transform:scale(.97);}
  .card .thumb{aspect-ratio:1;position:relative;display:flex;align-items:center;justify-content:center;
    background:radial-gradient(120% 120% at 30% 20%,#2c2419,#16130d);}
  .card .thumb .wm{font-family:var(--serif);font-size:54px;color:var(--ink);opacity:.16;}
  .card .thumb .reg{position:absolute;top:10px;left:11px;font-size:10px;letter-spacing:.1em;color:var(--gold);text-transform:uppercase;}
  .card .b{padding:11px 12px 13px;}
  .card .nm{font-size:12.5px;color:var(--ink);line-height:1.35;min-height:34px;}
  .card .ft{display:flex;align-items:center;justify-content:space-between;margin-top:8px;}
  .card .pr{font-family:var(--serif);font-weight:700;font-size:15px;color:var(--ink);}
  .card .pr i{color:var(--shu);font-style:normal;}
  .addmini{width:30px;height:30px;border-radius:50%;border:1px solid var(--shu);color:var(--shu);background:none;
    font-size:18px;line-height:1;display:flex;align-items:center;justify-content:center;cursor:pointer;}
  .addmini:active{background:var(--shu);color:#1a120e;}

  /* tab bar */
  .tabbar{position:absolute;left:0;right:0;bottom:0;height:84px;padding:10px 30px 26px;z-index:50;
    background:linear-gradient(to top,#100e0a 60%,rgba(16,14,10,.86));backdrop-filter:blur(10px);border-top:1px solid var(--line);
    display:flex;align-items:flex-start;justify-content:space-between;}
  .tab{display:flex;flex-direction:column;align-items:center;gap:4px;color:var(--muted);font-size:10px;cursor:pointer;background:none;border:none;flex:1;}
  .tab.on{color:var(--shu);}
  .tab svg{display:block;}
  .home-ind{position:absolute;bottom:8px;left:50%;transform:translateX(-50%);width:134px;height:5px;border-radius:3px;background:var(--ink);opacity:.5;z-index:70;}

  /* detail sheet */
  .scrim{position:absolute;inset:0;background:rgba(0,0,0,.55);opacity:0;pointer-events:none;transition:.28s;z-index:80;}
  .scrim.on{opacity:1;pointer-events:auto;}
  .sheet{position:absolute;left:0;right:0;bottom:0;background:var(--panel2);border-radius:26px 26px 0 0;z-index:90;
    transform:translateY(102%);transition:transform .34s cubic-bezier(.32,.72,0,1);max-height:80%;overflow-y:auto;border:1px solid var(--line);border-bottom:none;}
  .sheet.on{transform:translateY(0);}
  .sheet::-webkit-scrollbar{display:none;}
  .grip{width:38px;height:4px;border-radius:2px;background:#473e30;margin:11px auto 4px;}
  .sheet .big{aspect-ratio:1.4;margin:8px 18px 0;border-radius:18px;display:flex;align-items:center;justify-content:center;
    background:radial-gradient(120% 120% at 30% 20%,#332a1c,#15120c);position:relative;}
  .sheet .big .wm{font-family:var(--serif);font-size:96px;color:var(--ink);opacity:.18;}
  .sheet .big .reg{position:absolute;top:14px;left:16px;font-size:11px;letter-spacing:.12em;color:var(--gold);text-transform:uppercase;}
  .sheet .body{padding:18px 20px 16px;}
  .sheet .body h3{font-family:var(--serif);font-size:21px;color:var(--ink);font-weight:600;}
  .sheet .body .price{font-family:var(--serif);font-size:24px;color:var(--ink);margin-top:6px;}
  .sheet .body .price i{color:var(--shu);font-style:normal;}
  .sheet .body .desc{color:var(--muted);font-size:13px;line-height:1.65;margin-top:12px;}
  .sheet .meta{display:flex;gap:18px;margin-top:16px;padding-top:14px;border-top:1px solid var(--line);}
  .sheet .meta div{font-size:11px;color:var(--muted);}
  .sheet .meta b{display:block;color:var(--ink);font-family:var(--serif);font-size:13px;margin-bottom:2px;font-weight:600;}
  .cta{margin:18px 20px 26px;display:flex;gap:12px;}
  .cta button{flex:1;border:none;border-radius:14px;padding:16px;font-family:var(--sans);font-size:14px;font-weight:600;cursor:pointer;}
  .cta .buy{background:var(--shu);color:#1a120e;}
  .cta .fav{flex:0 0 54px;background:var(--panel);border:1px solid var(--line);color:var(--ink);}

  /* cart view */
  .cart-row{display:flex;gap:13px;align-items:center;padding:15px 20px;border-bottom:1px solid var(--line);}
  .cart-row .t{width:54px;height:54px;border-radius:13px;background:radial-gradient(120% 120% at 30% 20%,#2c2419,#16130d);
    display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-size:26px;color:var(--ink);opacity:.9;flex-shrink:0;}
  .cart-row .m{flex:1;min-width:0;}
  .cart-row .m .n{font-size:13px;color:var(--ink);}
  .cart-row .m .p{font-family:var(--serif);color:var(--gold);font-size:13px;margin-top:3px;}
  .cart-row .q{font-size:13px;color:var(--muted);}
  .cart-empty{text-align:center;color:var(--muted);font-size:13px;padding:80px 30px;}
  .cart-empty .e{font-family:var(--serif);font-size:46px;color:var(--ink);opacity:.2;display:block;margin-bottom:14px;}
  .checkout-bar{margin:18px 20px;border-top:1px solid var(--line);padding-top:16px;}
  .checkout-bar .tot{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:14px;}
  .checkout-bar .tot .l{font-size:12px;color:var(--muted);letter-spacing:.04em;}
  .checkout-bar .tot .v{font-family:var(--serif);font-size:23px;color:var(--ink);font-weight:700;}
  .checkout-bar button{width:100%;border:none;border-radius:14px;background:var(--shu);color:#1a120e;padding:16px;font-weight:600;font-size:14px;cursor:pointer;}

  .note{max-width:300px;color:#6f6657;font-size:12.5px;line-height:1.7;align-self:center;}
  .note h4{font-family:var(--serif);color:#9a8f7c;font-size:15px;margin-bottom:10px;}
  .note b{color:#b3a892;}

  /* --- logos --- */
  .brandlogo{height:38px;width:auto;mix-blend-mode:screen;filter:drop-shadow(0 0 8px rgba(210,96,63,.25));animation:logoglow 1.4s ease-out 1;}
  @keyframes logoglow{0%{filter:drop-shadow(0 0 0 rgba(210,96,63,0));opacity:.4}100%{filter:drop-shadow(0 0 8px rgba(210,96,63,.25));opacity:1}}

  #splash{position:absolute;inset:0;z-index:200;background:#0d0b07;display:flex;align-items:center;justify-content:center;
    transition:opacity .6s ease, transform .6s ease;}
  #splash::before{content:"";position:absolute;width:420px;height:420px;border-radius:50%;
    background:radial-gradient(circle,rgba(210,96,63,.28),rgba(201,168,106,.06) 45%,transparent 70%);
    filter:blur(6px);opacity:0;animation:bloom 2.6s ease-out forwards;}
  #splash.gone{opacity:0;transform:translateY(-22px);pointer-events:none;}
  .splash-wrap{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;}
  #splash .logoimg{width:240px;height:auto;mix-blend-mode:screen;opacity:0;transform:translateY(14px) scale(.96);
    animation:logoin 1s ease-out .25s forwards, flicker 2.6s steps(1) .9s 1;}
  .splash-line{width:0;height:2px;margin-top:6px;background:var(--shu);box-shadow:0 0 10px rgba(210,96,63,.6);
    animation:draw 0.7s ease-out 1.2s forwards;}
  .splash-skip{position:absolute;bottom:60px;left:0;right:0;text-align:center;color:#6f6657;font-size:11px;letter-spacing:.22em;
    text-transform:uppercase;opacity:0;animation:fadein .5s ease 1.8s forwards;}
  @keyframes bloom{0%{opacity:0;transform:scale(.6)}55%{opacity:1}100%{opacity:.8;transform:scale(1)}}
  @keyframes logoin{to{opacity:1;transform:none}}
  @keyframes draw{to{width:188px}}
  @keyframes fadein{to{opacity:1}}
  @keyframes flicker{0%{filter:brightness(.7)}6%{filter:brightness(1.25)}9%{filter:brightness(.85)}13%{filter:brightness(1.15)}18%{filter:brightness(1)}100%{filter:brightness(1)}}

</style>
</head>
<body>
<div class="stage-label">Lumik · prototype iOS hi-fi</div>

<div class="phone">
  <div class="notch"></div>
  <div id="splash" onclick="this.classList.add('gone')">
    <div class="splash-wrap">
      <img class="logoimg" src="data:image/png;base64," alt="LUMIK — Artisanat japonais, direct de la source">
      <div class="splash-line"></div>
    </div>
    <div class="splash-skip">Toucher pour entrer</div>
  </div>
  <div class="statusbar">
    <span>9:41</span>
    <span class="sb-r">
      <svg width="17" height="11" viewBox="0 0 17 11" fill="none"><rect x="0" y="7" width="3" height="4" rx="1" fill="#EFE7D8"/><rect x="4.5" y="5" width="3" height="6" rx="1" fill="#EFE7D8"/><rect x="9" y="2.5" width="3" height="8.5" rx="1" fill="#EFE7D8"/><rect x="13.5" y="0" width="3" height="11" rx="1" fill="#EFE7D8" opacity=".4"/></svg>
      <svg width="16" height="11" viewBox="0 0 16 11" fill="none"><path d="M8 2.2c2 0 3.8.8 5.2 2.1l1.1-1.2C12.6 1.4 10.4.5 8 .5S3.4 1.4 1.7 3.1l1.1 1.2C4.2 3 6 2.2 8 2.2z" fill="#EFE7D8"/><path d="M8 5.4c1.1 0 2.1.5 2.9 1.2l1.1-1.2C10.9 4.3 9.5 3.7 8 3.7s-2.9.6-4 1.7l1.1 1.2C5.9 5.9 6.9 5.4 8 5.4z" fill="#EFE7D8"/><circle cx="8" cy="9" r="1.6" fill="#EFE7D8"/></svg>
      <svg width="26" height="12" viewBox="0 0 26 12" fill="none"><rect x="1" y="1" width="21" height="10" rx="3" stroke="#EFE7D8" opacity=".5"/><rect x="2.5" y="2.5" width="17" height="7" rx="1.5" fill="#EFE7D8"/><rect x="23" y="4" width="2" height="4" rx="1" fill="#EFE7D8" opacity=".5"/></svg>
    </span>
  </div>

  <!-- ===== HOME / BOUTIQUE ===== -->
  <div class="view active" id="v-shop">
    <div class="app-head">
      <img class="brandlogo" src="data:image/png;base64," alt="LUMIK">
      <button class="icobtn" onclick="go('cart')" aria-label="Panier">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 6h15l-1.5 9h-12z"/><path d="M6 6L5 2H2"/><circle cx="9" cy="20" r="1.4"/><circle cx="18" cy="20" r="1.4"/></svg>
        <span class="badge" id="badge">0</span>
      </button>
    </div>

    <div class="hero">
      <div class="seal">灯</div>
      <div class="kj">Seki · Tokyo · Kyoto</div>
      <h1>Le quotidien japonais, direct de l'atelier.</h1>
      <p>Couteaux, céramique, washi. Choisis un à un, sans intermédiaire.</p>
    </div>

    <div class="chips" id="chips"></div>
    <div class="sec-title"><h2 id="secReg">Tout le Japon</h2><span id="secCount"></span></div>
    <div class="grid" id="grid"></div>
  </div>

  <!-- ===== CART ===== -->
  <div class="view" id="v-cart">
    <div class="app-head">
      <div class="brand" style="font-size:17px;">Panier 籠</div>
      <button class="icobtn" onclick="go('shop')" aria-label="Fermer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>
    <div id="cartItems"></div>
    <div class="checkout-bar" id="checkoutBar" style="display:none;">
      <div class="tot"><span class="l">SOUS-TOTAL</span><span class="v" id="cartTotal">0€</span></div>
      <button>Commander via WhatsApp</button>
    </div>
  </div>

  <!-- tab bar -->
  <div class="tabbar">
    <button class="tab on" id="tab-shop" onclick="go('shop')">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 10l8-6 8 6v9a1 1 0 01-1 1h-4v-6h-6v6H5a1 1 0 01-1-1z"/></svg>Accueil</button>
    <button class="tab" onclick="go('shop')">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>Boutique</button>
    <button class="tab" id="tab-cart" onclick="go('cart')">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 6h15l-1.5 9h-12z"/><path d="M6 6L5 2H2"/><circle cx="9" cy="20" r="1.3"/><circle cx="18" cy="20" r="1.3"/></svg>Panier</button>
    <button class="tab" onclick="go('shop')">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg>Compte</button>
  </div>
  <div class="home-ind"></div>

  <!-- detail sheet -->
  <div class="scrim" id="scrim" onclick="closeSheet()"></div>
  <div class="sheet" id="sheet">
    <div class="grip"></div>
    <div class="big"><span class="reg" id="dReg"></span><span class="wm" id="dWm">器</span></div>
    <div class="body">
      <h3 id="dName"></h3>
      <div class="price"><i id="dPrice"></i></div>
      <div class="desc" id="dDesc"></div>
      <div class="meta">
        <div><b>Origine</b><span id="dOrigin"></span></div>
        <div><b>Livraison</b><span>5–9 j · offerte dès 50€</span></div>
        <div><b>Retours</b><span>14 jours</span></div>
      </div>
    </div>
    <div class="cta">
      <button class="fav" aria-label="Favori">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 21s-7-4.5-9.5-9C1 9 2.5 5 6 5c2 0 3 1.2 4 2.5C11 6.2 12 5 14 5c3.5 0 5 4 3.5 7-2.5 4.5-9.5 9-9.5 9z"/></svg>
      </button>
      <button class="buy" id="dBuy">Ajouter au panier</button>
    </div>
  </div>
</div>

<div class="note">
  <h4>Maquette hi-fi · méthode huashu-design</h4>
  Prototype <b>cliquable</b> : touche une région pour filtrer, une pièce pour ouvrir la fiche, « ajouter » met à jour le panier et l'onglet.<br><br>
  Palette sumi de la marque, icônes SVG au trait, tuiles encre + filigrane kanji par région — <b>zéro emoji-icône</b>, zéro carte AI-slop.<br><br>
  Reflète la vraie data (régions Tokyo/Kyoto/Osaka/Seki…). À transposer en écran natif ou en pages Next.
</div>

<script>
  const SEUIL=50;
  const P=[
    {id:1,nom:'Couteau Santoku Seki',prix:52,region:'Seki',kj:'関',wm:'刃',desc:"Lame forgée à Seki, 700 ans de coutellerie. Acier dur, fil qui tient. Achetée directement à l'atelier."},
    {id:2,nom:'Bol à matcha chawan',prix:24,region:'Kyoto',kj:'京',wm:'茶',desc:"Grès émaillé pour le thé matcha, tourné à Kyoto. Chaque pièce porte la main de l'artisan."},
    {id:3,nom:'Bol Arita céramique',prix:18,region:'Arita',kj:'有',wm:'器',desc:"Porcelaine d'Arita, bleu-blanc traditionnel. Cuite à Saga, berceau de la porcelaine japonaise."},
    {id:4,nom:'Théière Tetsubin fonte',prix:48,region:'Iwate',kj:'岩',wm:'鉄',desc:"Fonte Nambu d'Iwate. Garde la chaleur, vieillit bien. Un objet pour des décennies."},
    {id:5,nom:'Couteau Sakai deba',prix:58,region:'Osaka',kj:'大',wm:'刃',desc:"Deba forgé à Sakai, près d'Osaka. La lame des chefs pour lever le poisson."},
    {id:6,nom:'Papier washi artisanal',prix:6,region:'Kyoto',kj:'京',wm:'紙',desc:"Washi pressé à la main. Pour la calligraphie, l'emballage ou l'encadrement."},
    {id:7,nom:'Bento deux étages',prix:26,region:'Tokyo',kj:'東',wm:'弁',desc:"Boîte-repas deux niveaux, usage quotidien. Pensée pour la main, pas pour la vitrine."},
    {id:8,nom:'Plateau laqué rouge',prix:32,region:'Kanazawa',kj:'金',wm:'漆',desc:"Laque urushi de Kanazawa. Le rouge profond qui se patine avec le temps."},
    {id:9,nom:'Furoshiki tissu noué',prix:14,region:'Tokyo',kj:'東',wm:'布',desc:"Carré de coton à nouer : sac, emballage cadeau, foulard. Le zéro-déchet japonais."},
    {id:10,nom:'Éventail sensu bambou',prix:13,region:'Kyoto',kj:'京',wm:'扇',desc:"Sensu pliant en bambou et papier, fait à Kyoto. Léger, pliable, élégant."}
  ];
  const REGIONS=[
    {n:'Tout le Japon',kj:'全',f:null},
    {n:'Tokyo',kj:'東',f:'Tokyo'},{n:'Kyoto',kj:'京',f:'Kyoto'},{n:'Osaka',kj:'大',f:'Osaka'},
    {n:'Seki',kj:'関',f:'Seki'},{n:'Arita',kj:'有',f:'Arita'},{n:'Kanazawa',kj:'金',f:'Kanazawa'},{n:'Iwate',kj:'岩',f:'Iwate'}
  ];
  let filtre=null, panier=[];

  const $=s=>document.querySelector(s);
  const liste=()=> filtre?P.filter(p=>p.region===filtre):P;

  function renderChips(){
    $('#chips').innerHTML=REGIONS.map((r,i)=>
      `<button class="chip ${((filtre===null&&r.f===null)||filtre===r.f)?'on':''}" onclick="setFiltre(${i})">
        <span class="cjp">${r.kj}</span>${r.n}</button>`).join('');
  }
  function setFiltre(i){ filtre=REGIONS[i].f; $('#secReg').textContent=REGIONS[i].n; renderChips(); renderGrid(); }

  function renderGrid(){
    const items=liste();
    $('#secCount').textContent=items.length+' pièces';
    $('#grid').innerHTML=items.map(p=>`
      <div class="card" onclick="openSheet(${p.id})">
        <div class="thumb"><span class="reg">${p.region}</span><span class="wm">${p.wm}</span></div>
        <div class="b">
          <div class="nm">${p.nom}</div>
          <div class="ft"><span class="pr">${p.prix}<i>€</i></span>
            <button class="addmini" onclick="event.stopPropagation();add(${p.id})">+</button></div>
        </div>
      </div>`).join('');
  }

  function openSheet(id){
    const p=P.find(x=>x.id===id);
    $('#dReg').textContent=p.region; $('#dWm').textContent=p.wm;
    $('#dName').textContent=p.nom; $('#dPrice').textContent=p.prix+'€';
    $('#dDesc').textContent=p.desc; $('#dOrigin').textContent=p.region+', Japon';
    $('#dBuy').onclick=()=>{ add(id); closeSheet(); };
    $('#scrim').classList.add('on'); $('#sheet').classList.add('on');
  }
  function closeSheet(){ $('#scrim').classList.remove('on'); $('#sheet').classList.remove('on'); }

  function add(id){ panier.push(id); updateCart(); pulse(); }
  function pulse(){ const b=$('#badge'); b.animate([{transform:'scale(1.5)'},{transform:'scale(1)'}],{duration:260}); }

  function updateCart(){
    const b=$('#badge'); b.textContent=panier.length; b.style.display=panier.length?'flex':'none';
    const g={}; panier.forEach(id=>g[id]=(g[id]||0)+1);
    const keys=Object.keys(g);
    const box=$('#cartItems'), bar=$('#checkoutBar');
    if(!keys.length){
      box.innerHTML=`<div class="cart-empty"><span class="e">籠</span>Votre panier est vide.<br>Ajoutez une pièce depuis la boutique.</div>`;
      bar.style.display='none'; return;
    }
    box.innerHTML=keys.map(id=>{ const p=P.find(x=>x.id==id),q=g[id];
      return `<div class="cart-row"><div class="t">${p.wm}</div>
        <div class="m"><div class="n">${p.nom}</div><div class="p">${p.prix*q}€</div></div>
        <div class="q">×${q}</div></div>`; }).join('');
    const total=panier.reduce((a,id)=>a+P.find(x=>x.id==id).prix,0);
    $('#cartTotal').textContent=total+'€'; bar.style.display='block';
  }

  function go(v){
    $('#v-shop').classList.toggle('active',v==='shop');
    $('#v-cart').classList.toggle('active',v==='cart');
    $('#tab-shop').classList.toggle('on',v==='shop');
    $('#tab-cart').classList.toggle('on',v==='cart');
    document.querySelectorAll('.view').forEach(el=>el.scrollTop=0);
  }

  renderChips(); renderGrid(); updateCart();
  setTimeout(()=>{const s=document.getElementById('splash');if(s)s.classList.add('gone');},2900);
</script>
</body>
</html>
